// packages\api\tsconfig.spec.json

{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "types": ["node", "jest"],
    "rootDir": ".",
    "noEmit": true
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.e2e-spec.ts",
    "src/**/__tests__/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}